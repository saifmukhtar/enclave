<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext (HTTP/WS) for local development.
        Add your dev machine's IP or use the Android emulator alias 10.0.2.2.
        Production traffic uses HTTPS enforced by the base-config below.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Add your local dev machine IP here, e.g.: -->
        <!-- <domain includeSubdomains="true">192.168.1.100</domain> -->
    </domain-config>

    <!-- All other traffic (your production domain) must use HTTPS -->
    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
