## Enclave Client Configuration Template
## Copy this file to 'local.properties' to configure your local compilation environment.
## Do NOT commit 'local.properties' to version control.

# Path to the local Android SDK installation directory
sdk.dir=/path/to/your/Android/Sdk

################################################################################
# RELEASE SIGNING CONFIGURATION
################################################################################
# Private Release Signing Configuration for Android APK signing.
# Leave blank to compile standard debug APKs.
RELEASE_STORE_FILE=/path/to/your/release-key.jks
RELEASE_STORE_PASSWORD=your_release_store_password
RELEASE_KEY_ALIAS=your_release_key_alias
RELEASE_KEY_PASSWORD=your_release_key_password

#################################################################################
# ADD YOUR SECRET AND PASTE IN THE APP DIRECTLY
#################################################################################
TURN_SERVER_URL=your_production_turn_url
TURN_USERNAME=your_production_turn_username
TURN_PASSWORD=your_production_turn_password
SIGNALING_SERVER_URL=your_production_server_url
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
NTFY_SERVER_URL=your_ntfy_server_url
NTFY_USERNAME=your_ntfy_username
NTFY_PASSWORD=your_ntfy_password