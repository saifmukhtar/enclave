# ==============================================================================
# Enclave Workspace Global Gitignore (Monorepo Consolidated)
# ==============================================================================

# OS / System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~
*.bak
*.tmp
*.log
*.codex
.remember/
# IDEs and Editors (Android Studio, VS Code, etc.)
.idea/
.agents/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.directory
logcat.txt
bugs.md
review/
release_test_log.txt
# ------------------------------------------------------------------------------
# Enclave Client (Android) Ignored Files
# ------------------------------------------------------------------------------
apps/android/local.properties
apps/android/app/google-services.json
apps/android/app/google-services.json.backup
apps/android/app/src/main/res/values/secrets.xml
apps/android/.gradle/
apps/android/build/
apps/android/app/build/
apps/android/captures/
apps/android/.externalNativeBuild/
apps/android/.cxx/
apps/android/*.jks
apps/android/*.keystore
apps/android/*.ap_
apps/android/*.der
apps/android/*.pk8
apps/android/*.pem
apps/android/logcat.txt
apps/android/logcat_problems.md
apps/android/.navigation/
apps/android/idea.properties

# ------------------------------------------------------------------------------
# Enclave Server (Backend) Ignored Files
# ------------------------------------------------------------------------------
backend/server/.env
backend/server/.env.backup
backend/server/.env.fixed
backend/server/signaling-server/firebase-adminsdk.json
backend/server/signaling-server/node_modules/
backend/server/signaling-server/dist/
backend/server/signaling-server.log
backend/server/volumes/db/data/
backend/server/signaling-server/package-lock.json
backend/server/signaling-server/npm-debug.log*
backend/server/signaling-server/yarn-debug.log*
backend/server/signaling-server/yarn-error.log*

# ------------------------------------------------------------------------------
# Global Build Outputs & Package Manager Cache Fallbacks
# ------------------------------------------------------------------------------
node_modules/
dist/
build/
.gradle/
out/
bin/
obj/
*.apk
*.aar
*.jar
!apps/android/gradle/wrapper/gradle-wrapper.jar
*.class

# Test outputs
testing/*/
*.db
*.db-shm
*.db-wal
testing/
apps/web/dist/
apps/web/node_modules/
apps/web/.env
