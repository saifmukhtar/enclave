## Enclave Server Environment Variables Template
## Copy this file to '.env' and update the values for your environment.
## Do NOT commit the active '.env' to public version control.

# --- Database Credentials ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_production_database_password
POSTGRES_PORT=5432

# --- JWT & Security Tokens ---
# Generate a secure 32+ character key for JWT_SECRET and 64+ hex for SECRET_KEY_BASE
JWT_SECRET=your_32_character_jwt_secret_key_placeholder
SECRET_KEY_BASE=your_64_character_hex_secret_key_base_placeholder
JWT_EXPIRY=86400
JWT_EXP=86400

# --- Supabase URLs (Production Domain) ---
# Replace 'your-domain.com' with your actual VPS public domain name
SUPABASE_PUBLIC_URL=https://api.your-domain.com
API_EXTERNAL_URL=https://api.your-domain.com
SUPABASE_URL=https://api.your-domain.com
SITE_URL=https://your-domain.com
GOTRUE_SITE_URL=https://your-domain.com

# --- Supabase API Keys (Self-Hosted) ---
# Map these tokens to authenticate static REST & Gotrue operations
ANON_KEY=your_supabase_anon_public_key_placeholder
SERVICE_ROLE_KEY=your_supabase_service_role_key_placeholder

# --- Network Ports ---
STUDIO_PORT=3000
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
META_PORT=8082

# --- Node.js Signaling WebSocket Server Settings ---
PORT=8085
MAX_CLIENTS=2
MAX_WS_PAYLOAD_BYTES=20971520
HEARTBEAT_INTERVAL_MS=30000

# --- Authentication Redirects ---
ADDITIONAL_REDIRECT_URLS=https://your-domain.com

# --- SSL/TLS Certificate Paths ---
SSL_CERT_PATH=/etc/letsencrypt/live/api.your-domain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/api.your-domain.com/privkey.pem

# --- Firebase Cloud Messaging (Optional Background Pushes) ---
FIREBASE_PROJECT_ID=enclave-firebase-project-id
GOOGLE_APPLICATION_CREDENTIALS=/opt/enclave-server/signaling-server/firebase-adminsdk.json
FIREBASE_CREDENTIALS_PATH=/opt/enclave-server/signaling-server/firebase-adminsdk.json

# --- STUN/TURN Media Relay ---
COTURN_AUTH_SECRET=your_static_auth_secret_for_stun_turn
COTURN_REALM=enclave.local

# --- PostgREST Schema ---
POSTGREST_DB_SCHEMA=public,storage,graphql_public

# --- Ntfy Push Notifications ---
NTFY_SERVER_URL=https://ntfy.your-domain.com
NTFY_USERNAME=your_ntfy_username
NTFY_PASSWORD=your_ntfy_password

